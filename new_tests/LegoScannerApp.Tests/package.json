{
  "name": "legoscannerapp-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.3",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/../../LegoScannerApp/$1",
      "^expo-camera$": "<rootDir>/__mocks__/expo-camera.ts",
      "^expo-haptics$": "<rootDir>/__mocks__/expo-haptics.ts",
      "^@supabase/supabase-js$": "<rootDir>/__mocks__/supabase.ts"
    },
    "setupFilesAfterEnv": []
  }
}
